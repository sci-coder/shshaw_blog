# Example workflow for building Hugo + Quarto together
# Rename to hugo.yaml to use this instead of the current workflow

name: Deploy Hugo + Quarto site to Pages

on:
  push:
    branches: ["main", "master"]
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: "pages"
  cancel-in-progress: false

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      # Install Hugo
      - name: Install Hugo CLI
        run: |
          wget -O ${{ runner.temp }}/hugo.deb https://github.com/gohugoio/hugo/releases/download/v0.120.4/hugo_extended_0.120.4_linux-amd64.deb \
          && sudo dpkg -i ${{ runner.temp }}/hugo.deb

      # Install Quarto
      - name: Set up Quarto
        uses: quarto-dev/quarto-actions/setup@v2
        with:
          version: 'latest'

      # Install R (if using R in Quarto)
      - name: Setup R
        uses: r-lib/actions/setup-r@v2
        if: false  # Set to true if you need R

      # Install Python (if using Python in Quarto)
      - name: Setup Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.11'
        if: false  # Set to true if you need Python

      # Checkout code
      - name: Checkout
        uses: actions/checkout@v4
        with:
          submodules: recursive
          fetch-depth: 0

      # Build Quarto documents
      - name: Render Quarto Projects
        run: |
          # Example: Render Quarto documents in quarto-content directory
          if [ -d "quarto-content" ]; then
            cd quarto-content
            quarto render
            # Copy rendered output to Hugo's static directory
            cp -r _site/* ../static/quarto-example/
            cd ..
          fi

      # Build Hugo site
      - name: Setup Pages
        id: pages
        uses: actions/configure-pages@v3

      - name: Build with Hugo
        env:
          HUGO_ENVIRONMENT: production
          HUGO_ENV: production
        run: |
          hugo \
            --gc \
            --minify \
            --baseURL "${{ steps.pages.outputs.base_url }}/"

      # Upload artifact
      - name: Upload artifact
        uses: actions/upload-pages-artifact@v2
        with:
          path: ./public

  deploy:
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    runs-on: ubuntu-latest
    needs: build
    steps:
      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v2